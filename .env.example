NODE_ENV=production

API_URL=https://api.astrid.global

REDIS_URL=redis://localhost:6379

VALIDATOR_MNEMONIC="seed phrase goes here"
HEARTBEAT_INTERVAL_MS=10000
MAX_CONCURRENT_TASKS=5

DOCKER_SOCKET=/var/run/docker.sock

VALIDATOR_DISPLAY_NAME=127 Validator

# URL to an icon image for the validator
VALIDATOR_ICON_URL=

BITTENSOR_ENABLED=true
BITTENSOR_WS_ENDPOINT="wss://entrypoint-finney.opentensor.ai:443"
BITTENSOR_NETUID=127
BITTENSOR_VERSION_KEY=0
BITTENSOR_WEIGHT_INTERVAL_MS=3600000
BITTENSOR_WEIGHT_TARGETS=164:1

VALIDATOR_MNEMONIC="..."
VALIDATOR_SS58_FORMAT=42
VALIDATOR_SS58_ADDRESS="..."
